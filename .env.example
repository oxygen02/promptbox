# PromptBox Backend API Keys
# 
# ⚠️ 安全提醒：这些是敏感信息，不要提交到 GitHub！
# 请复制此文件为 .env.local 并填入真实的 API Key

# ===================
# AI 模型 API Keys
# ===================

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Kimi API (月之暗面)
KIMI_API_KEY=sk-your-kimi-key

# MiniMax API
MINIMAX_API_KEY=sk-your-minimax-key

# 阿里云通义千问 API
QWEN_API_KEY=sk-53e8ae2bf4b043448a47083b1de5446e

# 腾讯云 API (用于 COS 存储等)
TENCENT_SECRET_ID=your-secret-id
TENCENT_SECRET_KEY=your-secret-key
TENCENT_COS_BUCKET=promptbox
TENCENT_COS_REGION=ap-guangzhou

# ===================
# 数据库配置
# ===================

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/promptbox

# Redis
REDIS_URL=redis://localhost:6379

# ===================
# 认证配置
# ===================

# NextAuth.js Secret
NEXTAUTH_SECRET=your-nextauth-secret-key
NEXTAUTH_URL=http://localhost:3000

# ===================
# 支付配置
# ===================

# 微信支付
WECHAT_MCH_ID=your-merchant-id
WECHAT_API_KEY=your-wechat-api-key

# 支付宝
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
